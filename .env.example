# GoHighLevel inbound-webhook URL (workflow trigger). Leads from the quote form
# are POSTed here as JSON with sourcePage, locale and submittedAt for attribution.
# Without it, submissions succeed but are only logged server-side.
GHL_WEBHOOK_URL=

# Google Analytics 4 measurement ID (G-XXXXXXXXXX). Analytics + conversion events
# (lead_form_submit, phone_click) load only when this is set.
NEXT_PUBLIC_GA_ID=

# Optional Google Search Console HTML-tag verification token. Use only the
# content value from the verification meta tag, not the full HTML element.
GOOGLE_SITE_VERIFICATION=
