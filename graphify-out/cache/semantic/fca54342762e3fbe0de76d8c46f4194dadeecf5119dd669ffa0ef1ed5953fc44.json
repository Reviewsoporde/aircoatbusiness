{"nodes": [{"id": "agents_doc", "label": "AGENTS.md (project conventions & hard rules)", "file_type": "document", "source_file": "AGENTS.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "concept_primary_color_black", "label": "Primary color: black (design decision)", "file_type": "rationale", "source_file": "AGENTS.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Client brief and July 2026 client feedback both mandate black/cool palette; warm palette experiments were tried and rejected twice, so friendliness is delivered via shape/type/motion instead of color."}, {"id": "concept_no_warm_tints_rule", "label": "Never introduce warm/cream/brown tints rule", "file_type": "rationale", "source_file": "AGENTS.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Guards against regressing the black/cool palette decision; explicitly bans ivory backgrounds, warm grays, warm-tinted shadows anywhere in the design system."}, {"id": "concept_rounded_geometry", "label": "Rounded geometry design system (pills, rounded-2xl)", "file_type": "concept", "source_file": "AGENTS.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Delivers the client-requested comfort/friendliness without touching the black color system: pill buttons, rounded-2xl cards, no sharp corners, no mono/uppercase UI labels."}, {"id": "concept_motion_system", "label": "CSS-first calm motion system (rise keyframes, Reveal, header-scroll-fx)", "file_type": "concept", "source_file": "AGENTS.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "No animation libraries; motion carries the 'friendliness' the client wants, respects prefers-reduced-motion."}, {"id": "concept_no_em_en_dash_rule", "label": "Never use em dash or en dash in public copy", "file_type": "rationale", "source_file": "AGENTS.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Copy style constraint; enforced mechanically by scripts/check-copy-style.mjs as part of the standard copy QA gate before delivery."}, {"id": "concept_nap_single_source_of_truth", "label": "NAP single source of truth (src/lib/site-config.ts)", "file_type": "concept", "source_file": "AGENTS.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Prevents inconsistent name/address/phone across the site by centralizing it in one config module, never hardcoded elsewhere."}, {"id": "concept_bilingual_nl_en", "label": "Bilingual NL (canonical) / EN (/en/) routing", "file_type": "concept", "source_file": "AGENTS.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Dutch URLs are canonical per site-architecture.md; English lives under /en/ with translated slugs via next-intl pathnames."}, {"id": "concept_b2b_positioning", "label": "Strict B2B positioning vs Airco@home consumer brand", "file_type": "rationale", "source_file": "AGENTS.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Site must never compete with the commercial CTA; consumer brand only gets a small, visually secondary residential redirect."}, {"id": "concept_lead_form_ghl_flow", "label": "Lead Form -> GoHighLevel webhook flow", "file_type": "concept", "source_file": "AGENTS.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "POST /api/lead re-validates with zod then forwards to GHL_WEBHOOK_URL with sourcePage/locale/submittedAt for CRM attribution; degrades to server log if unset."}, {"id": "concept_nextjs_breaking_changes_notice", "label": "\"This is NOT the Next.js you know\" breaking-changes notice", "file_type": "rationale", "source_file": "AGENTS.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Warns that this Next.js version diverges from training data conventions; explicitly calls out middleware.ts having been renamed to proxy.ts."}, {"id": "concept_mobile_first_perf", "label": "Fast + mobile-first performance rule (Lighthouse mobile >=90)", "file_type": "rationale", "source_file": "AGENTS.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Business visitors browse on the go; mandates next/image, lean JS, Lighthouse mobile >=90 / SEO 100."}, {"id": "concept_jsonld_schema_requirement", "label": "JSON-LD schema requirement (Organization/LocalBusiness/WebSite/ContactPoint/Service/BreadcrumbList/FAQPage)", "file_type": "concept", "source_file": "AGENTS.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Structured data was entirely absent on the old site (Rich Results Test showed none detected); FAQPage only added when the FAQ is visibly rendered."}, {"id": "concept_trailing_slash_urls", "label": "Dutch URLs verbatim with trailing slash (trailingSlash: true)", "file_type": "rationale", "source_file": "AGENTS.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Client-approved final URL structure must never be invented or renamed; trailingSlash true in next.config.ts is the technical enforcement mechanism."}], "edges": [{"source": "agents_doc", "target": "docs_projectinformation_doc", "relation": "references", "confidence": "INFERRED", "confidence_score": 0.85, "source_file": "AGENTS.md", "source_location": null, "weight": 1.0}, {"source": "agents_doc", "target": "docs_seo_strategy_doc", 